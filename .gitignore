.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==============================================================================
# Python
# ==============================================================================
# Compiled python bytecode files and cache directories
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ==============================================================================
# Virtual Environments
# ==============================================================================
# Local python virtual environments containing downloaded third-party packages
.venv/
venv/
ENV/
env/
ActiveState.venv/
pip-log.txt
pip-delete-this-directory.txt

# ==============================================================================
# Jupyter
# ==============================================================================
# Notebook checkpoint directories and auto-saved state
.ipynb_checkpoints/
.ipynb_checkpoints
*/.ipynb_checkpoints/

# ==============================================================================
# Logs
# ==============================================================================
# Log databases and text log outputs updated during prediction runs or unit testing
*.log
logs/
alerts.csv
test_alerts.csv

# ==============================================================================
# Experiment Outputs
# ==============================================================================
# ML experiment tracking logs and outputs (e.g. MLflow, Weights & Biases)
runs/
wandb/
mlruns/

# ==============================================================================
# Data Files
# ==============================================================================
# Large raw datasets and processed train/test files to keep repository lightweight
data/raw/UNSW_NB15_training-set.csv
data/raw/UNSW_NB15_testing-set.csv
data/processed/
data/output/

# ==============================================================================
# Model Files
# ==============================================================================
# Serialized model weights, scalers, and label encoders generated during training
models/*.pkl
models/*.keras
models/autoencoder_meta.json

# ==============================================================================
# Cache
# ==============================================================================
# Testing and performance caching files
.pytest_cache/
.tox/
.coverage
.cache
htmlcov/

# ==============================================================================
# IDE Files
# ==============================================================================
# IDE configurations containing user preferences, debug states, or local paths
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~

# ==============================================================================
# Docker
# ==============================================================================
# Docker environment files
.dockerignore

# ==============================================================================
# Build Artifacts
# ==============================================================================
# Compilation artifacts and dynamic python setup distributions
*.manifest
*.spec

# ==============================================================================
# Temporary Files
# ==============================================================================
# Temporary runtime caches
tmp/
temp/
*.tmp
*.bak

# ==============================================================================
# Secrets
# ==============================================================================
# Secret configuration files and private keys to prevent credentials leakage
.env
.env.*
.secrets
*.pem
*.key
*.pub
